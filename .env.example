# ─── Misinformation Detection Environment ───────────────────────────────────
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real tokens.

# LLM API endpoint (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1
# API_BASE_URL=https://router.huggingface.co/v1   # HF Inference Providers
# API_BASE_URL=http://localhost:1234/v1             # Local (LM Studio, Ollama)

# Model identifier
MODEL_NAME=gpt-4o-mini
# MODEL_NAME=openai/gpt-oss-120b                   # via HF router
# MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct     # via HF router

# API key — either variable name works:
HF_TOKEN=hf_your_huggingface_token_here
# OPENAI_API_KEY=sk-your_openai_key_here          # also accepted (alias for HF_TOKEN)

# OpenEnv server URL (override if running on HF Spaces)
SERVER_URL=http://localhost:7860
# SERVER_URL=https://your-username-misinformation-env.hf.space
